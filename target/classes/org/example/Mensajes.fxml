<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" prefHeight="640.0" prefWidth="360.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controller">
   <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="10">
         <children>
            <Button text="←" onAction="#irAFeed" style="-fx-background-color: #eee; -fx-background-radius: 10; -fx-font-weight: bold;" />
            <Label text="Mensajes Recibidos" style="-fx-font-size: 20; -fx-font-weight: bold;" />
         </children>
      </HBox>

      <ListView fx:id="listaMensajes" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;" />

      <HBox alignment="CENTER" spacing="15">
         <children>
            <Button onAction="#aceptarSolicitud" text="Aceptar" prefWidth="120" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 15;" />
            <Button onAction="#rechazarSolicitud" text="Rechazar" prefWidth="120" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 15;" />
         </children>
      </HBox>
   </children>
</VBox>