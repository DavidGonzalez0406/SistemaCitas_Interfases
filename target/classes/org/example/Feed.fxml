<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="640.0" prefWidth="360.0" style="-fx-background-color: #f9f9f9;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controller">
   <children>
      <AnchorPane prefHeight="60.0">
         <children>
            <Label text="Descubrir" AnchorPane.leftAnchor="20" AnchorPane.topAnchor="15" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF512F;" />
            <Button onAction="#irAMensajes" text="✉" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="12"
                    style="-fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-background-color: #FF512F; -fx-text-fill: white; -fx-font-size: 16;" />
         </children>
      </AnchorPane>

      <VBox maxWidth="320" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
         <children>
            <ImageView fx:id="imgPerfil" fitHeight="350.0" fitWidth="320.0" pickOnBounds="true" />
            <VBox spacing="5" style="-fx-padding: 15;">
               <children>
                  <Label fx:id="lblNombreEdad" style="-fx-font-size: 22; -fx-font-weight: bold;" />
                  <Label fx:id="lblBio" wrapText="true" style="-fx-text-fill: #666;" />
               </children>
            </VBox>
         </children>
      </VBox>

      <Region VBox.vgrow="ALWAYS" />
      <HBox alignment="CENTER" spacing="40" style="-fx-padding: 0 0 20 0;">
         <children>
            <Button onAction="#siguientePerfil" text="✘" style="-fx-background-radius: 50; -fx-min-width: 55; -fx-min-height: 55; -fx-background-color: white; -fx-text-fill: #ff4757; -fx-font-size: 22;" />
            <Button onAction="#irAContacto" text="❤" style="-fx-background-radius: 50; -fx-min-width: 55; -fx-min-height: 55; -fx-background-color: #FF512F; -fx-text-fill: white; -fx-font-size: 22;" />
         </children>
      </HBox>
   </children>
</VBox>