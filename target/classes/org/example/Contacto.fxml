<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" spacing="15.0" prefHeight="640.0" prefWidth="360.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controller">
   <padding><Insets top="30" right="30" bottom="20" left="30"/></padding>
   <children>
      <Label text="Perfil" style="-fx-font-size: 24; -fx-font-weight: bold;" />
      <ImageView fx:id="imgFotoPerfil" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />

      <VBox alignment="CENTER" spacing="5">
         <Label fx:id="lblNombrePersona" style="-fx-font-size: 18; -fx-font-weight: bold;" />
         <Label fx:id="lblBio" textAlignment="CENTER" wrapText="true" style="-fx-font-style: italic; -fx-text-fill: #555; -fx-padding: 0 10;" />
      </VBox>

      <ComboBox fx:id="cbModoContacto" promptText="Medio de contacto" prefWidth="300.0" />
      <TextArea fx:id="txtMensajeBreve" promptText="Escribe un mensaje..." prefHeight="80.0" wrapText="true" />

      <HBox spacing="10" alignment="CENTER">
         <Button text="Regresar" onAction="#irAFeed" style="-fx-background-color: #FF512F; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 20;" />
         <Button text="Enviar Match" onAction="#enviarSolicitud" style="-fx-background-color: #FF512F; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 20;" />
      </HBox>
   </children>
</VBox>